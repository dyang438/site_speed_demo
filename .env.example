# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# URL the GHA basic-action script POSTs to (e.g. https://your-app.vercel.app/api/action-runs)
API_ENDPOINT=****

# shared secret used by GitHub Actions when posting run data (must match app API_SECRET)
API_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****
